# ============================================
# Stokvel Backend Configuration
# ============================================
# SETUP: Copy this file to .env
#   Windows: copy .env.example .env
#   Mac/Linux: cp .env.example .env
# Then fill in your actual values below.
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
# Make sure MySQL is running before starting the server
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stokvel_db

# JWT (change this to a random string in production)
JWT_SECRET=stokvel-dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (SMTP) - for password reset (optional for development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
